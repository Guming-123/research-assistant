# Environment Configuration for Multi-Agent Literature Review System
# 环境配置文件示例
#
# 使用方法：复制此文件为 .env 并填入你的 API 密钥

# ========================================
# GLM API Configuration (智谱AI)
# ========================================
# GLM 官方文档: https://open.bigmodel.cn/usercenter/apikeys

OPENAI_API_KEY=your_glm_api_key_here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
OPENAI_MODEL=glm-4-plus

# GLM 模型选项:
# -------------------
# 对话模型:
# - glm-4-flash: 快速模型，适合大规模调用（类似 gpt-4o-mini）
# - glm-4-plus: 标准模型，适合通用任务（类似 gpt-4o）
# - glm-4: 基础模型
# - glm-4-long: 长上下文模型 (128K tokens)
# - glm-4-air: 经济型模型
#
# Embedding 模型:
# - embedding-2: 标准嵌入模型 (1024维)
# - embedding-3: 新一代嵌入模型 (1024维)

# ========================================
# OpenAI API Configuration (可选)
# ========================================
# 如需使用 OpenAI，注释掉上面的 GLM 配置，取消下面的注释：

# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ========================================
# Other API Options (可选)
# ========================================

# LiteLLM proxy (用于统一多个 LLM 提供商)
# LITELLM_API_KEY=your_litellm_key
# LITELLM_BASE_URL=https://litellm.example.com/v1

# Anthropic API (Claude 模型)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Semantic Scholar API (可选，用于更高的速率限制)
# SEMANTIC_SCHOLAR_API_KEY=your_s2_api_key_here

# ========================================
# Workspace Configuration
# ========================================
WORKSPACE_PATH=./workspace
CHECKPOINT_ENABLED=true

# ========================================
# Agent Configuration
# ========================================
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4000

# ========================================
# Search Configuration
# ========================================
DEFAULT_YEAR_START=2018
DEFAULT_YEAR_END=2025
DEFAULT_MAX_RESULTS=500

# ========================================
# Screening Configuration
# ========================================
DEFAULT_NF_THRESHOLD=0.7

# ========================================
# Clustering Configuration
# ========================================
DEFAULT_MIN_CLUSTER_SIZE=5
DEFAULT_CLUSTERING_METHOD=hdbscan

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO
LOG_FILE=./workspace/logs/system.log

# ========================================
# Rate Limiting
# ========================================
API_RATE_LIMIT=10
API_RETRY_ATTEMPTS=3
API_TIMEOUT=120