# Research Assistant 环境配置
# 复制此文件为 .env 并填入你的 API 密钥: cp .env.example .env

# ========================================
# LLM API 配置（必填）
# ========================================

# 智谱AI GLM（默认，推荐）
# 获取API Key: https://open.bigmodel.cn/usercenter/apikeys
OPENAI_API_KEY=your_glm_api_key_here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
OPENAI_MODEL=glm-5

# GLM模型选择:
#   glm-5        — 最新一代模型（默认，推荐）
#   glm-4-plus   — 标准模型，适合通用任务
#   glm-4-flash  — 快速模型，适合大规模调用（成本低）
#   glm-4-long   — 长上下文模型 (128K tokens)
#
# Embedding模型:
#   embedding-2  — 标准嵌入 (1024维)
#   embedding-3  — 新一代嵌入 (1024维)

# OpenAI（可选，替换上方GLM配置）
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ========================================
# 工作区
# ========================================
WORKSPACE_PATH=./workspace
CHECKPOINT_ENABLED=true

# ========================================
# Agent 配置
# ========================================
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=8000

# ========================================
# 搜索配置
# ========================================
DEFAULT_YEAR_START=2018
DEFAULT_YEAR_END=2025
DEFAULT_MAX_RESULTS=1000

# ========================================
# 筛选配置
# ========================================
DEFAULT_NF_THRESHOLD=0.68

# ========================================
# 聚类配置
# ========================================
DEFAULT_MIN_CLUSTER_SIZE=20
DEFAULT_CLUSTERING_METHOD=hdbscan

# ========================================
# 嵌入模型配置
# ========================================
# 远程API嵌入: embedding-3
# 本地GPU嵌入: local-zh (BGE-small-zh-v1.5)
EMBEDDING_MODEL=local-zh

# ========================================
# 日志
# ========================================
LOG_LEVEL=INFO
LOG_FILE=./workspace/logs/system.log

# ========================================
# API速率控制
# ========================================
API_RATE_LIMIT=10
API_RETRY_ATTEMPTS=3
API_TIMEOUT=120
